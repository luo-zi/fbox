<Window x:Class="Fbox.Gui.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="fbox"
        Width="340" Height="480"
        MinWidth="260" MinHeight="300"
        Topmost="True"
        WindowStyle="ToolWindow"
        AllowDrop="True"
        Loaded="OnLoaded"
        Closing="OnClosing">
    <Window.Resources>
        <Style x:Key="ToolBtn" TargetType="Button">
            <Setter Property="Width" Value="26"/>
            <Setter Property="Height" Value="24"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Margin" Value="2,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="#555"/>
        </Style>
    </Window.Resources>
    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,6">
            <TextBlock Text="fbox" FontWeight="Bold" FontSize="13" VerticalAlignment="Center"/>
            <TextBlock x:Name="CountBadge" Text="0" Foreground="Gray" FontSize="11"
                       VerticalAlignment="Center" Margin="6,0,0,0"/>
            <Button x:Name="RefreshBtn" Content="R" Style="{StaticResource ToolBtn}"
                    Click="Refresh_Click" ToolTip="刷新列表" Margin="12,0,0,0"/>
            <Button x:Name="ClearBtn" Content="X" Style="{StaticResource ToolBtn}"
                    Click="Clear_Click" ToolTip="清空全部"/>
        </StackPanel>

        <!-- Drop Zone -->
        <Border Grid.Row="1" x:Name="DropBorder"
                BorderBrush="#B0B0B0" BorderThickness="2" CornerRadius="8"
                Padding="16,20" Margin="0,0,0,6"
                AllowDrop="True"
                DragOver="DropBorder_DragOver"
                DragLeave="DropBorder_DragLeave"
                Drop="DropBorder_Drop"
                MouseDown="DropBorder_MouseDown">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="BorderBrush" Value="#B0B0B0"/>
                    <Style.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="#F0F6FF"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <TextBlock x:Name="DropHint"
                       Text="拖拽文件到此处&#x0a;或双击粘贴剪贴板中的文件路径"
                       TextWrapping="Wrap" HorizontalAlignment="Center"
                       TextAlignment="Center" Foreground="#999" FontSize="12"/>
        </Border>

        <!-- File List -->
        <ListBox Grid.Row="2" x:Name="FileListBox"
                 ItemsSource="{Binding}"
                 BorderThickness="0,1,0,0" BorderBrush="#E0E0E0"
                 VirtualizingPanel.ScrollUnit="Pixel"
                 FontSize="12">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Grid Margin="0,2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="F" FontWeight="Bold"
                                   Foreground="#666" Margin="0,0,6,0"/>
                        <StackPanel Grid.Column="1" Orientation="Vertical">
                            <TextBlock Text="{Binding FileName}" FontWeight="SemiBold"
                                       TextTrimming="CharacterEllipsis"/>
                            <TextBlock Text="{Binding Path}" Foreground="#999" FontSize="11"
                                       TextTrimming="CharacterEllipsis"
                                       ToolTip="{Binding Path}"/>
                        </StackPanel>
                        <TextBlock Grid.Column="2" Text="x"
                                   Foreground="#CCC" Cursor="Hand"
                                   ToolTip="从列表移除"
                                   MouseDown="RemoveItem_Click"
                                   Tag="{Binding Id}">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="#CCC"/>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Foreground" Value="#E53935"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Grid>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <!-- Status Bar -->
        <Border Grid.Row="3" Padding="0,4,0,0">
            <TextBlock x:Name="StatusText" Text="就绪" Foreground="#999" FontSize="11"/>
        </Border>
    </Grid>
</Window>
