<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net9.0-windows</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <UseWPF>true</UseWPF>
    <UseWindowsForms>true</UseWindowsForms>
    <RootNamespace>Fbox.Gui</RootNamespace>
  </PropertyGroup>
  <ItemGroup>
    <!-- Remove WinForms implicit usings to avoid namespace conflicts with WPF -->
    <Using Remove="System.Windows.Forms" />
  </ItemGroup>
  <ItemGroup>
    <ProjectReference Include="..\Fbox.Shared\Fbox.Shared.csproj" />
  </ItemGroup>
</Project>
